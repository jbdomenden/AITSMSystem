# Runtime environment
APP_ENV=development
PORT=8070

# Database (required)
DB_URL=jdbc:postgresql://localhost:5432/aitsm_db
DB_USER=postgres
DB_PASSWORD=root

# Superadmin bootstrap (required in production)
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=admin123!
SUPERADMIN_NAME=System Super Admin
SUPERADMIN_COMPANY=AITSM
SUPERADMIN_DEPARTMENT=Platform

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8070

# AI provider
AI_PROVIDER=ollama
AI_OLLAMA_BASE_URL=http://localhost:11434
AI_OLLAMA_MODEL=llama3.1:8b
AI_TIMEOUT_MILLIS=60000
